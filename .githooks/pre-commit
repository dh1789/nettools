#!/usr/bin/env bash
# nettools pre-commit 게이트.
# 활성화: git config core.hooksPath .githooks
# 우회 (권장 X): git commit --no-verify
set -e

ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT"

if ! command -v node >/dev/null 2>&1; then
  echo "❌ node 미설치 — pre-commit 게이트 실행 불가. brew reinstall node"
  exit 1
fi

# 1. 불변 조건 검증
echo "🔒 harness verify ..."
./bin/harness verify || {
  echo "❌ verify 실패 — 커밋 차단"
  exit 1
}

# 2. lint baseline 비교 (신규 ERROR 만 차단)
echo "🧹 harness lint (baseline 비교) ..."
current=$(./bin/harness lint --json | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>process.stdout.write(String(JSON.parse(d).error_count)))')
baseline=$(cat .harness-lint-baseline 2>/dev/null || echo 0)
if [ "${current:-0}" -gt "${baseline:-0}" ]; then
  echo "❌ 신규 lint ERROR $((current - baseline))건 추가됨 (baseline=${baseline}, current=${current})"
  echo "   ./bin/harness lint 로 위반 위치 확인."
  echo "   정당한 변경이면: ./bin/harness lint --json | node -e 'let d=\"\";process.stdin.on(\"data\",c=>d+=c);process.stdin.on(\"end\",()=>process.stdout.write(String(JSON.parse(d).error_count)))' > .harness-lint-baseline"
  exit 1
fi
echo "   lint OK (errors=${current} ≤ baseline=${baseline})"

# 3. type-check (변경된 .ts/.tsx 가 있을 때만)
if git diff --cached --name-only | grep -qE '\.(ts|tsx)$'; then
  echo "🧩 tsc --noEmit ..."
  npx --no-install tsc --noEmit || {
    echo "❌ 타입 에러 — 커밋 차단"
    exit 1
  }
fi

echo "✅ pre-commit 통과"
