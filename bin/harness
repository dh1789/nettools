#!/usr/bin/env node
// nettools 하네스 CLI 엔트리포인트.
// 자세한 사용법: docs/HARNESS_ENGINEERING.md
import { fileURLToPath } from "node:url";
import path from "node:path";

const __filename = fileURLToPath(import.meta.url);
const ROOT = path.resolve(path.dirname(__filename), "..");

process.chdir(ROOT);

const [, , cmd = "help", ...rest] = process.argv;
const flags = new Set(rest.filter((a) => a.startsWith("--")));
const opts = Object.fromEntries(
  rest
    .filter((a) => a.startsWith("--") && a.includes("="))
    .map((a) => a.replace(/^--/, "").split("="))
);
const positional = rest.filter((a) => !a.startsWith("--"));

const COMMANDS = {
  status: "status.mjs",
  verify: "verify.mjs",
  smoke: "smoke.mjs",
  lint: "lint.mjs",
  defects: "defects.mjs",
  drift: "drift.mjs",
  log: "log.mjs",
};

function help() {
  process.stdout.write(`bin/harness — nettools 자동 검증/진단 도구

사용:
  bin/harness <command> [options]

명령:
  status                시스템 상태 종합 리포트
  verify                불변 조건 검증 (pre-commit 게이트)   [실패 시 exit 1]
  lint                  컨벤션 위반 감지                       [정보용 exit 0]
  smoke                 5초 헬스 체크 (빌드/테스트/타입)
  defects               KNOWN_DEFECTS.md 미해결 결함 목록
  drift                 메모리 ↔ 현실 불일치 감지
  log [--recent N]      에이전트 작업 로그
  help                  이 도움말

공통 플래그:
  --json                JSON 출력 (스크립트 연동용)

자세한 내용: docs/HARNESS_ENGINEERING.md
`);
}

if (cmd === "help" || cmd === "--help" || cmd === "-h") {
  help();
  process.exit(0);
}

const moduleName = COMMANDS[cmd];
if (!moduleName) {
  process.stderr.write(`알 수 없는 명령: ${cmd}\n\n`);
  help();
  process.exit(2);
}

const mod = await import(path.join(ROOT, "scripts/harness", moduleName));
const code = await mod.run({ flags, opts, positional, root: ROOT });
process.exit(code ?? 0);
