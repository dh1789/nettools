# Site URL (Cloudflare Pages 배포 후 실제 도메인으로 변경)
NEXT_PUBLIC_SITE_URL=https://tools.example.com

# 광고 활성화 (트래픽 모일 때까지 false)
NEXT_PUBLIC_ADS_ENABLED=false

# Google AdSense Publisher ID (에드센스 승인 후 설정)
# 형식: ca-pub-XXXXXXXXXXXXXXXX
# 이 값이 설정되면 layout.tsx에서 AdSense 스크립트가 자동 삽입됩니다.
NEXT_PUBLIC_ADSENSE_ID=
